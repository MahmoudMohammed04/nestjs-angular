
generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}


model User{
  id String @id 
  email String @unique
  normalizedEmail String @unique
  username String
  normalizedUsername String
  phone String
  pictureUrl String

  messages Message[]
  messagesStatus MessageStatus[]
  memberships ConversationMember[]

  @@index([normalizedUsername])
}

model Conversation{
  id Int @id @default(autoincrement())
  name String?
  imageUrl String?
  isGroup Boolean
  lastMessageId Int? @unique
  lastMessage Message? @relation(name:"lastMessageConversation",references: [id],fields: [lastMessageId])
  lastMessageTime DateTime?
  membersCount Int

  messages Message[]
  members ConversationMember[]
}

model ConversationMember {
  userId String
  user User @relation(fields: [userId], references: [id])
  conversationId Int
  conversation Conversation @relation(fields: [conversationId], references: [id])

  role ConversationRole @default(member)
  joinedAt DateTime @default(now())
  
  lastReadedMessageId Int?
  lastReadedMessage Message? @relation(name: "lastReadedMessage",fields: [lastReadedMessageId],references: [id],onDelete: SetNull)  
  lastDeliveredMessageId Int?
  lastDeliveredMessage Message? @relation(name: "lastDeliveredMessage", fields: [lastDeliveredMessageId],references: [id],onDelete: SetNull) 

  @@id([userId, conversationId])
}


enum ConversationRole {
  member
  admin
  owner
}

model Message{
  id Int @id  @default(autoincrement())
  content String
  sentAt DateTime
  conversationMembersCount Int

  conversationId Int 
  conversation Conversation @relation(fields: [conversationId], references: [id])



  senderId String
  sender User @relation(fields: [senderId],references: [id])

  messageFiles MessageFile[]
  messageStatus MessageStatus[]

  readByMembers ConversationMember[] @relation("lastReadedMessage")
  deliveredByMembers ConversationMember[] @relation("lastDeliveredMessage")

  conversationLastMessage Conversation? @relation(name: "lastMessageConversation")

}

model MessageFile{
  id Int @id @default(autoincrement())
  fileUrl String
  fileType FileType
  messageId Int
  message Message @relation(fields: [messageId],references: [id])
}

enum FileType {
  IMG
  BDF
}

model MessageStatus{
  messageId Int
  messages Message  @relation(fields: [messageId],references: [id])
  userId String 
  user User @relation(fields: [userId],references: [id])

  status MessageStatusType
  updatedAt DateTime @updatedAt

  @@id([messageId,userId])
}

enum MessageStatusType {
  None
  Seen
  delivered
}





